# Application
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fastify_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fastify_db
DB_USER=postgres
DB_PASSWORD=postgres

# Security
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_MAX=100
RATE_LIMIT_TIMEWINDOW=60000
