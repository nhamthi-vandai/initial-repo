# Application
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fastify_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fastify_db
DB_USER=postgres
DB_PASSWORD=postgres

# MongoDB (NoSQL)
MONGODB_URL=mongodb://localhost:27017/fastify_db

# Authentication (JWT)
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=24h

# Security
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_MAX=100
RATE_LIMIT_TIMEWINDOW=60000

# Internationalization
DEFAULT_LANGUAGE=en
